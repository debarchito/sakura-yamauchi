{
  "name": "sakura-yamauchi",
  "version": "0.0.1-indev",
  "description": "A Discord bot created in the memory of Sakura Yamauchi (Kanji: 山内桜良) ",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "start": "cd dist && node index.js",
    "run": "pnpm build && pnpm start",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "@discordjs/builders": "^0.6.0",
    "@discordjs/rest": "^0.1.0-canary.0",
    "canvas": "^2.8.0",
    "discord-api-types": "^0.22.0",
    "discord.js": "^13.2.0",
    "dotenv": "^10.0.0",
    "realm": "^10.8.0"
  },
  "devDependencies": {
    "@types/node": "^16.11.0",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "prettier": "^2.4.1",
    "typescript": "^4.4.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debarchito/sakura-yamauchi.git"
  },
  "keywords": [
    "sakura",
    "yamauchi",
    "sakura-yamauchi"
  ],
  "author": "Debarchito Nath",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/debarchito/sakura-yamauchi/issues"
  },
  "homepage": "https://github.com/debarchito/sakura-yamauchi#readme"
}
