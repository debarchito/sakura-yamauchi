{
  "name": "sakura-yamauchi",
  "version": "0.0.1",
  "description": "A Discord bot created in the memory of Sakura Yamauchi (Kanji: 山内桜良)",
  "type": "module",
  "scripts": {
    "build": "swc src/ -d dist/",
    "build:watch": "pnpm watch \"swc src/ -d dist/\" src",
    "start": "cd dist && node index.js",
    "start:watch": "cd dist && nodemon -w ../dist index.js",
    "dev": "concurrently \"pnpm build:watch\" \"pnpm start:watch\"",
    "tsc": "tsc",
    "tsc:watch": "tsc -w",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier -w ."
  },
  "dependencies": {
    "canvas": "^2.9.0",
    "discord-tictactoe": "^3.0.0",
    "discord.js": "^13.6.0",
    "discord.js-minesweeper": "^1.1.0",
    "dotenv": "^10.0.0",
    "realm": "^10.16.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.57",
    "@swc/core": "^1.2.176",
    "@types/node": "^17.0.31",
    "@typescript-eslint/eslint-plugin": "^5.22.0",
    "@typescript-eslint/parser": "^5.22.0",
    "concurrently": "^7.1.0",
    "eslint": "^8.14.0",
    "eslint-config-prettier": "^8.5.0",
    "nodemon": "^2.0.16",
    "prettier": "^2.6.2",
    "typescript": "^4.6.4"
  },
  "engines": {
    "node": ">= 16.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debarchito/sakura-yamauchi.git"
  },
  "keywords": [
    "sakura",
    "yamauchi",
    "sakura-yamauchi"
  ],
  "author": "Debarchito Nath",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/debarchito/sakura-yamauchi/issues"
  },
  "homepage": "https://github.com/debarchito/sakura-yamauchi#readme"
}
